rules:
  - selectorRegexp: ^(k8s.io/kubernetes/test/utils/ktesting|k8s.io/klog|github.com/go-logr|github.com/onsi/gomega|go.uber.org/goleak)
    allowedPrefixes: [ "" ]
  # TODO (?): move into ktesting?
  - selectorRegexp: k8s.io/kubernetes/test/utils/format
    allowedPrefixes: [ "" ]
  # TODO (?): make the necessary functionality a valid dependency of all Kubernetes packages?
  - selectorRegexp: k8s.io/component-base/logs
    allowedPrefixes: [ "" ]
  # TODO: remove usage of testify in favor of gomega
  - selectorRegexp: ^github.com/stretchr/testify/
    allowedPrefixes: [ "" ]
  # Any package without a dot in the first part of the name is a standard package.
  - selectorRegexp: ^[a-z]*($|/)
    allowedPrefixes: [ "" ]
  - selectorRegexp: .*
    forbiddenPrefixes: [ "" ]
